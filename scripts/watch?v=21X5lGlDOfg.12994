EC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMIuuqA-fyVkwMVk7wrBh3wCR38SPjzjMrGsv6q2wHKAQQPV0c7","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFdwRjg2ZjR5YndmWHl2eFZPODEwV0UxMlU0UXxBQ3Jtc0ttclNtMGxiZk95ODNob0YxcmdNSXVPZkNoRGhVbFpDUl9ZNldIT29uVlVkX1VTNWFYLVBGWFNubjhfdzZtYl9FLVJjMzNPaW56c3QyaDhrRzNWXzNfUzZSazdIbjFsY0t6MFNNV1FRU2FSZHhMZWo0aw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFdwRjg2ZjR5YndmWHl2eFZPODEwV0UxMlU0UXxBQ3Jtc0ttclNtMGxiZk95ODNob0YxcmdNSXVPZkNoRGhVbFpDUl9ZNldIT29uVlVkX1VTNWFYLVBGWFNubjhfdzZtYl9FLVJjMzNPaW56c3QyaDhrRzNWXzNfUzZSazdIbjFsY0t6MFNNV1FRU2FSZHhMZWo0aw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"US