itemprop="interactionType" content="https://schema.org/WatchAction"><meta itemprop="userInteractionCount" content="149281002"></div><meta itemprop="datePublished" content="2018-12-28T10:40:15-08:00"><meta itemprop="uploadDate" content="2018-12-28T10:40:15-08:00"><meta itemprop="genre" content="Science &amp; Technology"><span itemprop="publication" itemscope itemtype="http://schema.org/BroadcastEvent"><meta itemprop="isLiveBroadcast" content="True"><meta itemprop="startDate" content="2018-12-28T18:41:41+00:00"><meta itemprop="endDate" content="2024-08-30T19:11:47+00:00"></span></div></head><body dir="ltr" no-y-overflow><script nonce="f8lH9SysWtjLR6TcN1Gu5Q">var ytInitialPlayerResponse = {"responseContext":{"visitorData":"Cgs4TjFnYklPdWc3ZyiD1qDOBjIKCgJVUxIEGgAgSYIB3wKJY-8walZZ9Cw15llDJEFF0n7ZIiOH2VnK3HIcIabbHagt9Zk6wP2AUl0a1Y9NHh6fcQbEP6jOADm4g03fqzTNiIa-ycjeayieNabJLF2S9Au7b0AnJcvr7E0SZXOor7Nslek5jNiydYzGbW-5OfU4yWyVwTSva2ahAartrhsZb7ldhJd7FmJmRHkgVeLqu-YQJ_-YVAe-WN0475v_c7umPpCFbJYqQFcebWLPc6ymRCKMfkc54UntoidnR-AaW-0_h76-uZ96kfSQjwD_hTChNi8rJYkTGFobfvpa8A0RtWOu9OUU0WbiKZEClKaO2tVtO6wcUUTkas_NQ_2GFAZpW__-I2m6U-QhoSpz8eAuAnpuB8DyoQaR0_MkVbvIqHXIP1YZBZz_yxW0GHjtgkmQUVJFxHQtsjMPs92U4MNRwHAbELPIP5WA3DBFNisklH5_EkaItIt7UaW3hT79rXM%3D","serviceTrackingParams":[{"service":"GFEEDBACK","params":[{"key":"is_alc_surface","value":"false"},{"key":"ipcc","value":"0"},{"key":"is_viewed_live","value":"True"},{"key":"logged_in","value":"0"},{"key":"visitor_data","value":"Cgs4TjFnYklPdWc3ZyiD1qDOBjIKCgJVUxIEGgAgSQ%3D%3D"}]},{"service":"CSI","params":[{"key":"c","value":"WEB"},{"key":"cver","value":"2.20260325.08.00"},{"key":"yt_li","value":"0"},{"key":"GetPlayer_rid","value":"0x35a267b2a7b11f55"}]},{"service":"GUIDED_HELP","params":[{"key":"logged_in","value":"0"}]},{"service":"ECATCHER","params":[{"key":"client.version","value":"2.20260325"},{"key":"client.name","value":"WEB"}]}],"maxAgeSeconds":0,"mainAppWebResponseContext":{"loggedOut":true,"trackingParam":"kx_fmPxhoPZR34D_YFgYQtPl4lgogpOmMKrvAqkMEIm3QpzRgkuMsNLBwOcCE59TDtslLKPQ-SS"},"webResponseContextExtensionData":{"webResponseContextPreloadData":{"preloadMessageNames":["playerErrorMessageRenderer","miniplayerRenderer","playerMicroformatRenderer"]},"hasDecorated":true}},"playabilityStatus":{"status":"UNPLAYABLE","reason":"This live stream recording is not available.","errorScreen":{"playerErrorMessageRenderer":{"reason":{"simpleText":"This live stream recording is not available."},"thumbnail":{"thumbnails":[{"url":"//s.ytimg.com/yts/img/meh7-vflGevej7.png","width":140,"height":100}]},"icon":{"iconType":"ERROR_OUTLINE"}}},"playableInEmbed":true,"miniplayer":{"miniplayerRenderer":{"playbackMode":"PLAYBACK_MODE_ALLOW"}},"contextParams":"Q0FFU0FnZ0M="},"videoDetails":{"videoId":"21X5lGlDOfg","title":"NASA Live: Official Stream of NASA TV","lengthSeconds":"179022606","keywords":["science","space","technology","nasa","nasa live","nasa tv","247","live"],"channelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isOwnerViewing":false,"shortDescription":"UPDATE: Our 24/7 NASA TV broadcast is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet. \n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches. \n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","isCrawlable":false,"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=CODToM4G-oaymwEiCKgBEF5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLBCL6nfLF59VH8rsQmBsk_dSmTgKg","width":168,"height":94},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=CODToM4G-oaymwEiCMQBEG5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLBjbFwcjeLUgjUqvHdNcWiPJw5uPQ","width":196,"height":110},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=CODToM4G-oaymwEjCPYBEIoBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLAvlOczwUhN3uUAONCK31X7C8RaQQ","width":246,"height":138},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=CODToM4G-oaymwEjCNACELwBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLAzprRDZkCqBBCLIONCxyHI6t86PA","width":336,"height":188},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/maxresdefault.jpg?v=6412256d","width":1920,"height":1080}]},"allowRatings":true,"viewCount":"149281002","author":"NASA","isLowLatencyLiveStream":false,"isPrivate":false,"isUnpluggedCorpus":false,"latencyClass":"MDE_STREAM_OPTIMIZATIONS_RENDERER_LATENCY_NORMAL","isLiveContent":true,"isPostLiveDvr":true,"isTvfilmVideo":false},"microformat":{"playerMicroformatRenderer":{"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/maxresdefault.jpg?v=6412256d","width":1280,"height":720}]},"embed":{"iframeUrl":"https://www.youtube.com/embed/21X5lGlDOfg","width":480,"height":360},"title":{"simpleText":"NASA Live: Official Stream of NASA TV"},"description":{"simpleText":"UPDATE: Our 24/7 NASA TV broadcast is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet. \n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches. \n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception."},"lengthSeconds":"179022606","ownerProfileUrl":"http://www.youtube.com/@NASA","externalChannelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isFamilySafe":true,"availableCountries":["AD","AE","AF","AG","AI","AL","AM","AO","AQ","AR","AS","AT","AU","AW","AX","AZ","BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BQ","BR","BS","BT","BV","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN","CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC","EE","EG","EH","ER","ES","ET"