MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPkBEM2rARgBIhMIrunL4P__kwMVWgBXAR2KlinjSPjzjMrGsv6q2wHKAQS8LQJB","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbkY2eS1KNnB2MENPbnRpLUtPT3NYS3M3UzNhd3xBQ3Jtc0ttUHFDakFXcWljZDB0X2RBdUFPSlNWWlBQRlZWd3pSR1pfaDc4WXNMNlZMUnJVeVV2V3VqbVhyci0zZ3hTTllMX2N0X1lMeGJPN191dERNZHEtZ1lUeDVWQUNnNG11YnFyUXlzQ2JKaVV2a1ZaeVVfYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbkY2eS1KNnB2MENPbnRpLUtPT3NYS3M3UzNhd3xBQ3Jtc0ttUHFDakFXcWljZDB0X2RBdUFPSlNWWlBQRlZWd3pSR1pfaDc4WXNMNlZMUnJVeVV2V3VqbVhyci0zZ3hTTllMX2N0X1lMeGJPN191dERNZHEtZ1lUeDVWQUNnNG11YnFyUXlzQ2JKaVV2a1ZaeVVfYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"s