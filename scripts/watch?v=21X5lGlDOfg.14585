a":{"sendPost":true,"apiUrl":"/youtubei/v1/subscription/unsubscribe"}},"unsubscribeEndpoint":{"channelIds":["UCLA_DiR1FfKNvjuUpBHmylQ"],"params":"CgIIAxILMjFYNWxHbERPZmcYAA%3D%3D"}},"accessibility":{"label":"Unsubscribe"},"trackingParams":"CLEBEPBbIhMIufuw-sHJlQMVf7rRBB3pDTy4"}},"cancelButton":{"buttonRenderer":{"style":"STYLE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"Cancel"}]},"accessibility":{"label":"Cancel"},"trackingParams":"CLABEPBbIhMIufuw-sHJlQMVf7rRBB3pDTy4"}},"primaryIsCancel":false}},"popupType":"DIALOG"}}]}}]}},"metadataRowContainer":{"metadataRowContainerRenderer":{"collapsedItemCount":0,"trackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4"}},"showMoreText":{"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"trackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4","defaultExpanded":false,"descriptionCollapsedLines":3,"showMoreCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4ygEELc6pxw==","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4ygEELc6pxw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_EXPANDED"}},{"clickTrackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4ygEELc6pxw==","scrollToEngagementPanelCommand":{"targetId":"engagement-panel-structured-description"}}]}},"showLessCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4ygEELc6pxw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},"attributedDescription":{"content":"UPDATE: Our 24/7 NASA TV broadcast is being phased out as of Aug. 28, 2024. We will continue to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet. \n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches. \n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMIufuw-sHJlQMVf7rRBB3pDTy4SPjzjMrGsv6q2wHKAQQtzqnH","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjRoSm42X2gzb3pIb1ZrNTl4TG5LS0NjMXdXd3xBQ3Jtc0ttcnN5ZlBwUWlSS294TnBSZ190Tk5lWHNQa1R6bFRWZkh2a3drZ1pTalZtTFVoNHZsckJZemdFQXlVTjBXcVhGNURDMlpCVjRiODUwWnUtMGhzNUZwNXdkTEdHMHB3bTJQX0prSUpub2dzY1hrOC1nYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjRoSm42X2gzb3pIb1ZrNTl4TG5LS0NjMXdXd3xBQ3Jtc0ttcnN5ZlBwUWlSS294TnBSZ190Tk5lWHNQa1R6bFRWZkh2a3drZ1pTalZtTFVoNHZsckJZemdFQXlVTjBXcVhGNURDMlpCVjRiODUwWnUtMGhzNUZwNXd