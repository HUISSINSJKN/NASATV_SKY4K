 needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAUiEwiY9PzF0MCTAxVoyJUCHc5kLLpI-POMysay_qrbAcoBBADO9cw=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0J6YmQ3QTFCZFRHdU5aejdPaUdaLWRvVWxDUXxBQ3Jtc0tucGYxRXl0SlB2TWk1RUMzdl9TY0p4Z1kxSHYtdzJ3Yl8zcm02bmNHeFdvWEZrcklULUFnVTVFaTdhV0lqcUROb0hIQUpuejhXLV9NTmdNdVA0TFVqT2FTSmdsQlRicmxjNTk0bmc3LVRNWEx5QmNmNA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0J6YmQ3QTFCZFRHdU5aejdPaUdaLWRvVWxDUXxBQ3Jtc0tucGYxRXl0SlB2TWk1RUMzdl9TY0p4Z1kxSHYtdzJ3Yl8zcm02bmNHeFdvWEZrcklULUFnVTVFaTdhV0lqcUROb0hIQUpuejhXLV9NTmdNdVA0TFVqT2FTSmdsQlRicmxjNTk0bmc3LVRNWEx5QmNmNA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT","val