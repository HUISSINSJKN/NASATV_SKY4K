 States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPYBEM2rARgBIhMIk5D6n6SHkwMVy4llAx2a6yWrSPjzjMrGsv6q2wHKAQQgtoJp","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFRSdzZvODlRb2Fua18yWFBtbENhcExtSGJ4UXxBQ3Jtc0ttUmYydm43U3FMMWJzUktvNDRVOC16N3NVTU9GdWVzVk14aERZbHhDYWt6SU1HQ1JPSUVacE94TksyMTBWREFqbW5wN3pBYkhZSzgyc1pSamtoRmxTVUZHWE5oS3lSLWNSX1BsYU1NbHpOZWV0dGZwYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFRSdzZvODlRb2Fua18yWFBtbENhcExtSGJ4UXxBQ3Jtc0ttUmYydm43U3FMMWJzUktvNDRVOC16N3NVTU9GdWVzVk14aERZbHhDYWt6SU1HQ1JPSUVacE94TksyMTBWREFqbW5wN3pBYkhZSzgyc1pSamtoRmxTVUZHWE5oS3lSLWNSX1BsYU1NbHpOZWV0dGZwYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":9