ated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPgBEM2rARgBIhMIkuzb4s7vkwMVRi9XAR0pZAI7SPjzjMrGsv6q2wHKAQTuiF1A","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDBvQUVBZFZ4dlBWMDQwOWhNY1ZjLXFGVkNlUXxBQ3Jtc0trZnd4UjVGN0NBSHgyUl9PRTRhbm84S3picFlZTDZZQ2ZTdHpOU0tIZDN3TFdva1ZyUmdiTnFWR01FNUpVRkh5RXJ6d3Rmd0tHOEVOdmpRZTdpa0hiN3dDaEg2Z0VrZzFDamJhb29XMGhObmtMNnA2Yw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDBvQUVBZFZ4dlBWMDQwOWhNY1ZjLXFGVkNlUXxBQ3Jtc0trZnd4UjVGN0NBSHgyUl9PRTRhbm84S3picFlZTDZZQ2ZTdHpOU0tIZDN3TFdva1ZyUmdiTnFWR01FNUpVRkh5RXJ6d3Rmd0tHOEVOdmpRZTdpa0hiN3dDaEg2Z0VrZzFDamJhb29XMGhObmtMNnA2Yw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"US