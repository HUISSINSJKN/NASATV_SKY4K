ata rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAUiEwjBoIfezruTAxVPmooHHUBUHxFI-POMysay_qrbAcoBBBE0HCk=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa285ZlNzNG5FaXF3T25EekFhNENLa1BTdkxuQXxBQ3Jtc0tsLXFCSHBUUEE4SGJMcmhNOTRoaFB3S1B6TzdKQ0JFZnplU2VqemRJNHpIWWFySExPdUdBU1ctcGg0WFZnYWMtc1RXckt4M0REcFlLbWxkYXVaakV0Z1hzVjc3YjRaTFZaX3dPNnRMY2xvbWdFSE1kbw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa285ZlNzNG5FaXF3T25EekFhNENLa1BTdkxuQXxBQ3Jtc0tsLXFCSHBUUEE4SGJMcmhNOTRoaFB3S1B6TzdKQ0JFZnplU2VqemRJNHpIWWFySExPdUdBU1ctcGg0WFZnYWMtc1RXckt4M0REcFlLbWxkYXVaakV0Z1hzVjc3YjRaTFZaX3dPNnRMY2xvbWdFSE1kbw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunEx