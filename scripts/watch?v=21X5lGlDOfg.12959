eceiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMIx4GLy7eRkwMVZhCGAB2jOji6SPjzjMrGsv6q2wHKAQQjnQ3p","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUx3c0dPMlotOU9weTEzSGlBZ1paVEJvNFBhQXxBQ3Jtc0tsaG5sbE8tZk80MF80M2xMU1VJQlpJX1lZNHlnSVhEbDlJYzNjTHlBUGdaa1A4LXluNnBZSlM4aHVyOThaRVNPeU9ja1c4STFMTDRZaWFzd3pMWHQteU1NdWV0R0tJbndJd2oyZVZUX0cwbjM1bzVQRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUx3c0dPMlotOU9weTEzSGlBZ1paVEJvNFBhQXxBQ3Jtc0tsaG5sbE8tZk80MF80M2xMU1VJQlpJX1lZNHlnSVhEbDlJYzNjTHlBUGdaa1A4LXluNnBZSlM4aHVyOThaRVNPeU9ja1c4STFMTDRZaWFzd3pMWHQteU1NdWV0R0tJbndJd2oyZVZUX0cwbjM1bzVQRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INT