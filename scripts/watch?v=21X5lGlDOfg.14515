EC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKwBEM2rARgBIhMI9dPx2Jm3lQMVRA5tBx0fujc8SPjzjMrGsv6q2wHKAQReBbC6","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjY0bFNoVkVubDJ1V0J1ajRCSlRfMnBISkU3QXxBQ3Jtc0trc0R4ek4wcVZkaGM4WDJmc1RKanRPYjZXVi1JS0VTdVJjSGhla0FhRExaTEluN1hKcFBNMXRCX3Q3WVZEakJ6OXlmbjc4N1JQNVFBcnIwM1AtY09IS0FTMkdfQlVXYjhoemo4UEZ2ZjZoc3d5V0ZvSQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjY0bFNoVkVubDJ1V0J1ajRCSlRfMnBISkU3QXxBQ3Jtc0trc0R4ek4wcVZkaGM4WDJmc1RKanRPYjZXVi1JS0VTdVJjSGhla0FhRExaTEluN1hKcFBNMXRCX3Q3WVZEakJ6OXlmbjc4N1JQNVFBcnIwM1AtY09IS0FTMkdfQlVXYjhoemo4UEZ2ZjZoc3d5V0ZvSQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"US