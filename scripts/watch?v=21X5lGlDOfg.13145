temprop="interactionType" content="https://schema.org/WatchAction"><meta itemprop="userInteractionCount" content="149281002"></div><meta itemprop="datePublished" content="2018-12-28T10:40:15-08:00"><meta itemprop="uploadDate" content="2018-12-28T10:40:15-08:00"><meta itemprop="genre" content="Science &amp; Technology"><span itemprop="publication" itemscope itemtype="http://schema.org/BroadcastEvent"><meta itemprop="isLiveBroadcast" content="True"><meta itemprop="startDate" content="2018-12-28T18:41:41+00:00"><meta itemprop="endDate" content="2024-08-30T19:11:47+00:00"></span></div></head><body dir="ltr" no-y-overflow><script nonce="BCwoI3jUvrio4ElvXaqIag">var ytInitialPlayerResponse = {"responseContext":{"visitorData":"_k3gy3ObnEUN4NkHq_Os4uaE7k9LXsJeEDNwWycq2Q2ERXa2V0b2XEDum0Owj4x972zY8icjv6lXEBS9oEpXbUQLK4tsuKTan6Rhdn-VPulWbKQvlKMtOpbGvx31bYmJO656mVGSs4ZxJp6I_yvBhQz4ovMZdkTqKa7ajX2k4_qKkmhqjvZZ5UptitQAOcrzmCDezIQy2RbkRHIBc7LPIV3PNJGqBmsylfhd8M_Z1KlWLTftlfEVVnN2wnJe7VpXxbvpLu31U_ns8bEQzKecRI-3u2KoqwAYTImD5ip1r8w_jf2KbhQFGdr_TB4n31rB1dKhpgwDM-DAGs-WKGLXlN_GYQ6r1Qvo-v8E1rbWsidlIkX7kE6QC50F-xmEKQyqOuPv-MyS0-K4iZVQx3KDdE6rsjOuZTqi-PUpKN4nsTyZhxyfj-UCR3WKpqhdKO20mz6Ns22p_JOr71VN4O38%3D","serviceTrackingParams":[{"service":"GFEEDBACK","params":[{"key":"is_alc_surface","value":"false"},{"key":"ipcc","value":"0"},{"key":"is_viewed_live","value":"True"},{"key":"logged_in","value":"0"},{"key":"visitor_data","value":"%3D%3D"}]},{"service":"CSI","params":[{"key":"c","value":"WEB"},{"key":"cver","value":"2.20260317.01.00"},{"key":"yt_li","value":"0"},{"key":"GetPlayer_rid","value":"0xc169d1c0d53dc78f"}]},{"service":"GUIDED_HELP","params":[{"key":"logged_in","value":"0"}]},{"service":"ECATCHER","params":[{"key":"client.version","value":"2.20260317"},{"key":"client.name","value":"WEB"}]}],"maxAgeSeconds":0,"mainAppWebResponseContext":{"loggedOut":true,"trackingParam":"kx_fmPxhoPZRj9Kl4lwqg3DAPAhME1e1zQfGDrk6gS2YbZzRgkuMsNLBwOcCE59TDtslLKPQ-SS"},"webResponseContextExtensionData":{"webResponseContextPreloadData":{"preloadMessageNames":["playerErrorMessageRenderer","miniplayerRenderer","playerMicroformatRenderer"]},"hasDecorated":true}},"playabilityStatus":{"status":"UNPLAYABLE","reason":"This live stream recording is not available.","errorScreen":{"playerErrorMessageRenderer":{"reason":{"simpleText":"This live stream recording is not available."},"thumbnail":{"thumbnails":[{"url":"//s.ytimg.com/yts/img/meh7-vflGevej7.png","width":140,"height":100}]},"icon":{"iconType":"ERROR_OUTLINE"}}},"playableInEmbed":true,"miniplayer":{"miniplayerRenderer":{"playbackMode":"PLAYBACK_MODE_ALLOW"}},"contextParams":"Q0FFU0FnZ0M="},"videoDetails":{"videoId":"21X5lGlDOfg","title":"NASA Live: Official Stream of NASA TV","lengthSeconds":"179022606","keywords":["science","space","technology","nasa","nasa live","nasa tv","247","live"],"channelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isOwnerViewing":false,"shortDescription":"UPDATE: Our 24/7 NASA TV broadcast is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet. \n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches. \n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","isCrawlable":false,"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=COSb6s0G-oaymwEiCKgBEF5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLBjo_RY6icD0HmHapFonjmtmaLqVw","width":168,"height":94},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=COSb6s0G-oaymwEiCMQBEG5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLD3byxffLN5KM9GTj7HG6nOg34O3w","width":196,"height":110},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=COSb6s0G-oaymwEjCPYBEIoBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLCakIlNhZ0buo62QkntJADgqN952g","width":246,"height":138},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/hqdefault.jpg?v=6412256d\u0026sqp=COSb6s0G-oaymwEjCNACELwBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLAG8KLxHSZw_il5Q_0JIw4vZ0IRAw","width":336,"height":188},{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/maxresdefault.jpg?v=6412256d","width":1920,"height":1080}]},"allowRatings":true,"viewCount":"149281002","author":"NASA","isLowLatencyLiveStream":false,"isPrivate":false,"isUnpluggedCorpus":false,"latencyClass":"MDE_STREAM_OPTIMIZATIONS_RENDERER_LATENCY_NORMAL","isLiveContent":true,"isPostLiveDvr":true,"isTvfilmVideo":false},"microformat":{"playerMicroformatRenderer":{"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/21X5lGlDOfg/maxresdefault.jpg?v=6412256d","width":1280,"height":720}]},"embed":{"iframeUrl":"https://www.youtube.com/embed/21X5lGlDOfg","width":480,"height":360},"title":{"simpleText":"NASA Live: Official Stream of NASA TV"},"description":{"simpleText":"UPDATE: Our 24/7 NASA TV broadcast is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet. \n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches. \n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception."},"lengthSeconds":"179022606","ownerProfileUrl":"http://www.youtube.com/@NASA","externalChannelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isFamilySafe":true,"availableCountries":["AD","AE","AF","AG","AI","AL","AM","AO","AQ","AR","AS","AT","AU","AW","AX","AZ","BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BQ","BR","BS","BT","BV","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN","CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC","EE","EG","EH","ER","ES","ET","FI","FJ","FK","FM","FO","FR","GA","GB","GD","GE","GF","GG","GH","GI","GL","GM","GN","GP"