0 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CLQBEM2rARgBIhMIis-VmoivlAMVR4O6AB1JzyzPSPjzjMrGsv6q2wHKAQRK9a08","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbEpNMDNCOFN3V2otQS0xQlVjRmhadG1XejFUd3xBQ3Jtc0tsNHU1cVdHWVhSb2hlanhUcGY3RDF5UkNjVFZfRTJfMms0Yjl1YS1uNVRFZi1sWi1NY0dUY3BObkNIZXpUZ3BQYlNPT05xbjMtSHM5ajZteGlSODcySjBRM0hLenVjNV9GRjI1WUt6cnF1U2dBWnRLUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbEpNMDNCOFN3V2otQS0xQlVjRmhadG1XejFUd3xBQ3Jtc0tsNHU1cVdHWVhSb2hlanhUcGY3RDF5UkNjVFZfRTJfMms0Yjl1YS1uNVRFZi1sWi1NY0dUY3BObkNIZXpUZ3BQYlNPT05xbjMtSHM5ajZteGlSODcySjBRM0hLenVjNV9GRjI1WUt6cnF1U2dBWnRLUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{