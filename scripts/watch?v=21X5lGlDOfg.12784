ansponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiakcOFmPySAxXkTz8BHUtaEulI-POMysay_qrbAcoBBN0oT6g=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa3NMclJIRFk5VDlZMUQ5S3J5MFJjQm1XWDloZ3xBQ3Jtc0tudnlsaTY3aHFuUkZfcGR1Rms1aGFLYUR4SE1SRjhBSENfdWpqbDhZc0tMRGRuMHlWNm9GVnluVWZCdlFHNFlibHlDaWxSd3JjMGJFOTJoVEhoNnJwVVlDalhUSWhfUGprVF9HdVRTRWRpMW9icGJPUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa3NMclJIRFk5VDlZMUQ5S3J5MFJjQm1XWDloZ3xBQ3Jtc0tudnlsaTY3aHFuUkZfcGR1Rms1aGFLYUR4SE1SRjhBSENfdWpqbDhZc0tMRGRuMHlWNm9GVnluVWZCdlFHNFlibHlDaWxSd3JjMGJFOTJoVEhoNnJwVVlDalhUSWhfUGprVF9HdVRTRWRpMW9icGJPUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_INTERFACE_THEME_LIGHT","value":4281736458}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294634464},{"key":"USER_I