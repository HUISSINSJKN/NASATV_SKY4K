ant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPsBEM2rARgBIhMIx47U1YD7kgMVpX4_AR1NwDgeSPjzjMrGsv6q2wHKAQTyLmDb","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjVsNVFxY3NWOEpWckNkWTJZRkZRcGxMRy1xd3xBQ3Jtc0tsSnlaSDR5ZGh6X3FSZ0JTMGVmYnAzb2VmMndxNEcxWEJFaDhNd05mT0ZPOUs3MHVuX0NfOGR3SFU2Mi1wVl95Z2FRX0xjMnVDSkVRNUc1SDNYbjJrQXBMRWVOMXhvUGJKVDVXV19GZ2VzcFhWNjk4RQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjVsNVFxY3NWOEpWckNkWTJZRkZRcGxMRy1xd3xBQ3Jtc0tsSnlaSDR5ZGh6X3FSZ0JTMGVmYnAzb2VmMndxNEcxWEJFaDhNd05mT0ZPOUs3MHVuX0NfOGR3SFU2Mi1wVl95Z2FRX0xjMnVDSkVRNUc1SDNYbjJrQXBMRWVOMXhvUGJKVDVXV19GZ2VzcFhWNjk4RQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},