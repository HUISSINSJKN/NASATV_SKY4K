C. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKwBEM2rARgBIhMI04Sx85allAMVyw17Ah1NexmQSPjzjMrGsv6q2wHKAQQMScGS","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbW9XeU50VHB2ODFsY2N5SnBRN2dFX3lNalBkZ3xBQ3Jtc0tsdGRQby1ESjFLT0tBbHBzdTNMN1NSc0dYY3lLQkEwcThXUS11M0Z1R3FUT3k1UndtcVE5QVVPLVFlV0pKYmJsaThxUzZ2X2lNcFd5N2x0cFFjT3U5d1ZxN1duZUJ1TVJLTXBlTDN6RHRJSEtXQUp4dw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbW9XeU50VHB2ODFsY2N5SnBRN2dFX3lNalBkZ3xBQ3Jtc0tsdGRQby1ESjFLT0tBbHBzdTNMN1NSc0dYY3lLQkEwcThXUS11M0Z1R3FUT3k1UndtcVE5QVVPLVFlV0pKYmJsaThxUzZ2X2lNcFd5N2x0cFFjT3U5d1ZxN1duZUJ1TVJLTXBlTDN6RHRJSEtXQUp4dw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USE