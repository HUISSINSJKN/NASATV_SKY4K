00 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPYBEM2rARgBIhMI8_-msIyYkwMVmLsrBh1HoTs-SPjzjMrGsv6q2wHKAQSQyIZ4","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblRLQXloWVlTMnNFaFIzdWpHSkgyQUl3Yll6Z3xBQ3Jtc0trelhhdnJ1LTJpRVR6cC1BWG1XWnd0MWo1MDlxRl9SeWZGSUNQcEZtQ2RJUmJiOUg3ZjE2OWFydXd1N0FrMy1GRWZVTW90Y29GU3BBamRFRnhXWWJObGJDSm44T0xRYU9mR2dDSGloSGJDVEdpaWRPRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblRLQXloWVlTMnNFaFIzdWpHSkgyQUl3Yll6Z3xBQ3Jtc0trelhhdnJ1LTJpRVR6cC1BWG1XWnd0MWo1MDlxRl9SeWZGSUNQcEZtQ2RJUmJiOUg3ZjE2OWFydXd1N0FrMy1GRWZVTW90Y29GU3BBamRFRnhXWWJObGJDSm44T0xRYU9mR2dDSGloSGJDVEdpaWRPRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"col