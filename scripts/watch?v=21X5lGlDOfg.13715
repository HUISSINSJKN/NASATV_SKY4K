ion on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPgBEM2rARgBIhMItZOyw8_5kwMVLU3CAR3nyARRSPjzjMrGsv6q2wHKAQQhuqxQ","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbVZ0WEFUVHlmbHk0VXd2U3FDaUFDOEZ3QTlVd3xBQ3Jtc0ttX3F0Q0dBSTZ3UTBqODlrNG1sRy16NldJQW02ZkREbVg2NGx1Mi12RlVxaWVYcG9wVTF5Z3hUX0tDX1hGRDIxQlk4a0NqWXFTSlA4UWhNNFhuYTl3TW1WUE9XYThqYjlFa2pLdVM2X045a1JtLU9uVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbVZ0WEFUVHlmbHk0VXd2U3FDaUFDOEZ3QTlVd3xBQ3Jtc0ttX3F0Q0dBSTZ3UTBqODlrNG1sRy16NldJQW02ZkREbVg2NGx1Mi12RlVxaWVYcG9wVTF5Z3hUX0tDX1hGRDIxQlk4a0NqWXFTSlA4UWhNNFhuYTl3TW1WUE9XYThqYjlFa2pLdVM2X045a1JtLU9uVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","val