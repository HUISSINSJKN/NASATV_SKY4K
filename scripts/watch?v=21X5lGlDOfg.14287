ied by DVB-S2/8PSK modulation on satellite Galaxy 13, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKwBEM2rARgBIhMIy9uDyqTylAMVgY1lAx1u2gM3SPjzjMrGsv6q2wHKAQRJZ1Pl","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2NQSGI3NnBPRlhMbUtrVzhrVGQ0VGJCdnA3UXxBQ3Jtc0tuRWlIOTk4Rkh0Q2ZvQVYwaHlYNXNWTEdnWkJUMUxJWjB5b1E0LXFNNmo5d0JKWUN3ekRtVmhaYVpFaVFpSmRmV3AtYmtEYzN0NVJpS0VXa084LXVrSHVzUHBUMk9FVWpMRHZFSFVEalFuV3dBRlRpYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2NQSGI3NnBPRlhMbUtrVzhrVGQ0VGJCdnA3UXxBQ3Jtc0tuRWlIOTk4Rkh0Q2ZvQVYwaHlYNXNWTEdnWkJUMUxJWjB5b1E0LXFNNmo5d0JKWUN3ekRtVmhaYVpFaVFpSmRmV3AtYmtEYzN0NVJpS0VXa084LXVrSHVzUHBUMk9FVWpMRHZFSFVEalFuV3dBRlRpYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_