compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":338,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKsBEM2rARgBIhMIjtHG4KmjlQMVa46KBx38ggdCSPjzjMrGsv6q2wHKAQRwTb17","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHQ4WTRaT1d1elB0ZmZUS242c0ttOE9WSWZfUXxBQ3Jtc0trbHJJaE9VV2ZMMTVoa1dxQzBTS0xvVVRvN3JSay02VU9Ca0NDenE3a2dIakMzWEE1SW1YUi00dkhCM3FlcC0tUWo3YkZaQzZkTUVtVFYtXzdGTjBOeHMwRjhtbWoxbnNHTzdRTW96WXEtSDYwN290WQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHQ4WTRaT1d1elB0ZmZUS242c0ttOE9WSWZfUXxBQ3Jtc0trbHJJaE9VV2ZMMTVoa1dxQzBTS0xvVVRvN3JSay02VU9Ca0NDenE3a2dIakMzWEE1SW1YUi00dkhCM3FlcC0tUWo3YkZaQzZkTUVtVFYtXzdGTjBOeHMwRjhtbWoxbnNHTzdRTW96WXEtSDYwN290WQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=21X5lGlDOfg","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":79,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":79,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":92,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":338,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":428229